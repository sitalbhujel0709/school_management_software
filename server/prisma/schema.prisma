// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

model User {
  id String @id @default(uuid())
  email String @unique
  password String?
  name String
  role Role
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())

  student Student?
  teacher Teacher?
  otps Otp[]
  sessions Session[]
}

model Student {
  id String @id @default(uuid())
  userId String @unique

  user User @relation(fields:[userId],references:[id])
  courses Enrollment[]
  attendances attendence[]
}

model Teacher {
  id String @id @default(uuid())
  userId String @unique

  courses course_teacher[]
  user User @relation(fields:[userId],references:[id])
  attendances attendence[]
}

model Course {
  id String @id @default(uuid())
  name String
  description String
  credits Int

  enrollments Enrollment[]
  teachers course_teacher[]
  attendances attendence[]
}

model Enrollment {
  id String @id @default(uuid())
  studentId String
  courseId String


  student Student @relation(fields:[studentId],references:[id])
  course Course @relation(fields:[courseId],references:[id])
}

model course_teacher {
  id String @id @default(uuid())
  courseId String
  teacherId String

  course Course @relation(fields:[courseId],references:[id])
  teacher Teacher @relation(fields:[teacherId],references:[id])
}

model attendence {
  id String @id @default(uuid())
  date DateTime
  status AttendanceStatus
  studentId String
  courseId String
  teacherId String

  student Student @relation(fields:[studentId],references:[id])
  course Course @relation(fields:[courseId],references:[id])
  teacher Teacher @relation(fields:[teacherId],references:[id])
}


model Otp {
  id String @id @default(uuid())
  email String
  code String
  expiresAt DateTime
  revoked Boolean @default(false)
  userId String 

  user User @relation(fields:[userId],references:[id])
}

model Session {
  id String @id @default(uuid())
  userId String
  refreshToken String
  expiresAt DateTime
  ip String
  userAgent String
  revoked Boolean @default(false)

  user User @relation(fields:[userId],references:[id])
}